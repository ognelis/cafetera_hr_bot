# Cafetera HR Bot — environment variables
# Copy to .env and fill in real values.

# ── cafetera-vk-bot ──────────────────────────────────────────────
# Variables needed by the VK polling bot (cafetera_vk_bot)
VK_ACCESS_TOKEN=your_vk_community_token_here
VK_GROUP_ID=0

# ── RAG Service (cafetera-rag-service) ──────────────────────────
# Variables consumed by the RAG microservice (port 8001).
# Admin and VK bot communicate with the RAG service via HTTP.
# RAG service handles the full document pipeline: download from S3,
# parse (Docling), chunk, embed, and index into Qdrant.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hr_documents
# Timeout in seconds for Qdrant operations (default 300s)
# QDRANT_TIMEOUT=300

# LLM (ollama | openai | llamacpp)
# Provider is selected interactively at startup. Set here only if you want to skip the menu.
# Default: llamacpp (best memory control with q8_0 KV cache quantization)
LLM_PROVIDER=llamacpp
# LLM_MODEL is ONLY used by Ollama provider (model name in Ollama library).
# For llamacpp, this is just an API label — actual model is controlled by LLM_MODEL_PATH.
LLM_MODEL=qwen3.5:9b-q4_K_M
# LLM_BASE_URL and EMBEDDING_BASE_URL are set automatically based on provider selection.
# Do NOT set them here — they are configured at runtime by startup scripts.
# LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=

# Skip interactive provider menu (default: false).
# When true, startup scripts (run_admin.sh, run_admin_docker.sh, run_all.sh,
# ragas/run.sh) do NOT prompt for LLM / Embedding provider and apply values
# from this .env directly.
#
# Required .env vars per provider when SKIP_PROVIDER_MENU=true:
#   ollama   — LLM_PROVIDER, EMBEDDING_PROVIDER (models optional, have sane defaults).
#   openai   — LLM_PROVIDER=openai, LLM_API_KEY, EMBEDDING_PROVIDER=openai, EMBEDDING_API_KEY.
#   llamacpp — LLM_PROVIDER=llamacpp, EMBEDDING_PROVIDER=llamacpp
#              (.gguf models under models/ are auto-downloaded on first run).
SKIP_PROVIDER_MENU=false

# LLM sampling parameters (optional).
# Defaults: only LLM_TEMPERATURE is forwarded; the others fall back to the
# backend's own defaults if left unset.
# Example for t-tech/T-lite-it-2.1 recommended generation params:
#   LLM_TEMPERATURE=0.7
#   LLM_TOP_P=0.8
#   LLM_TOP_K=20
#   LLM_PRESENCE_PENALTY=1.0
# Notes:
#   - top_k is non-standard for OpenAI; forwarded to vLLM/llama-server via extra_body.
#   - presence_penalty is ignored by the Ollama backend (it uses repeat_penalty).
LLM_TEMPERATURE=0.2
# Optimized for CHUNK_SIZE=512: 10 chunks × 512 + query + answer ≈ 6500 tokens
LLM_NUM_CTX=8192
LLM_MAX_TOKENS=4096
# LLM_TOP_P=
# LLM_TOP_K=
# LLM_PRESENCE_PENALTY=

# Disable thinking/reasoning mode for Qwen3/Qwen3.5 models (Ollama and llamacpp; default: true)
LLM_DISABLE_THINKING=true

# KV Cache quantization for llama-server (saves VRAM with minimal quality impact)
# q8_0: 50% VRAM savings, <1% quality loss (recommended for production)
# q5_0: 68% VRAM savings, 1-3% quality loss (use if VRAM is very limited)
# f16: no quantization, maximum quality (default if unset)
# LLM_CACHE_TYPE_K=q8_0
# LLM_CACHE_TYPE_V=q8_0

# Parallel requests limit for llama-server (controls max concurrent generations)
# Prevents KV Cache explosion under high load by queuing excess requests
# Default 5: supports ~5-10 RPS depending on response length
# Increase for higher throughput (requires more VRAM): 10-20
# Decrease for limited VRAM: 2-3
# LLM_PARALLEL=5

# ── Embedding ───────────────────────────────────────────────────
# Provider is selected interactively at startup. Set here only if you want to skip the menu.
# Default: llamacpp (matches LLM provider for consistency)
EMBEDDING_PROVIDER=llamacpp
# EMBEDDING_MODEL is ONLY used by Ollama provider (model name in Ollama library).
# For llamacpp, this is just an API label — actual model is controlled by EMBED_MODEL_PATH.
EMBEDDING_MODEL=qwen3-embedding:4b-q4_K_M
# EMBEDDING_BASE_URL is set automatically based on provider selection.
# EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_API_KEY=

# Max texts per API request to the embedding server (prevents KV cache overflow in llama-server)
# Formula: EMBED_CTX_SIZE >= EMBEDDING_CHUNK_SIZE × CHUNK_SIZE
# Default 8 works with EMBED_CTX_SIZE=4096 and CHUNK_SIZE=512 (saves 50% VRAM vs 16)
# For higher throughput: EMBEDDING_CHUNK_SIZE=16 + EMBED_CTX_SIZE=8192
EMBEDDING_CHUNK_SIZE=8

SPARSE_EMBEDDING_MODEL=Qdrant/bm25
# Russian lemmatization for BM25 (pymorphy3); disable for non-Russian corpora
BM25_LEMMATIZE=true

# ── Embedding Query Instruction ────────────────────────────────
# Asymmetric query-side instruction for Qwen3 / E5-instruct family models.
# Applied to queries only: "Instruct: {task}\nQuery: {text}"
# Leave empty or set embedding_use_query_instruction=false for symmetric models (e.g., BGE-M3).
EMBEDDING_QUERY_INSTRUCTION=Given a web search query, retrieve relevant passages that answer the query
EMBEDDING_USE_QUERY_INSTRUCTION=true

# --- Reranker (llama.cpp / Jina-compatible endpoint) ---
RERANKING_ENABLED=true
# RERANKER_URL is set automatically based on runtime context:
#   - Docker scripts: http://host.docker.internal:8082
#   - Local scripts: http://localhost:8082
# RERANKER_URL=http://localhost:8082
RERANKER_TOP_N=10
RERANKER_PREFETCH_LIMIT=15
RERANKER_TIMEOUT=30.0
# For run_llama_reranker.sh:
RERANKER_MODEL=Qwen3-Reranker-0.6B
RERANKER_MODEL_PATH=./models/Qwen3-Reranker-0.6B-Q4_K_M.gguf
RERANKER_N_GPU_LAYERS=
RERANKER_CTX_SIZE=8192
RERANKER_BATCH_SIZE=2048
RERANKER_UBATCH_SIZE=2048

# Retrieval k defaults
# Optimized for CHUNK_SIZE=512: fewer chunks fit in LLM context
DOC_QUERY_K=10
GLOBAL_MAX_K=10

# Dense-branch cosine similarity score threshold (disables pre-fusion filtering by default).
# 0.0 = no filtering (recommended for uncalibrated embeddings like Qwen3 0.6B on Russian).
# Raise only if your embedding model produces well-calibrated cosine scores.
DENSE_SCORE_THRESHOLD=0.0

# Chunking (token counts — uses tiktoken for accurate token measurement)
# Default 512 tokens stays well under llama-server's 512 default batch
CHUNK_SIZE=512

# Tokenizer model for HybridChunker (HuggingFace model name)
# Must match the tokenizer of the embedding model for accurate token counting.
# For qwen3-embedding Ollama models, all sizes share the same tokenizer.
CHUNKER_TOKENIZER_MODEL=Qwen/Qwen3-Embedding-0.6B

# Internal RAG microservice URL and API key
RAG_SERVICE_URL=http://localhost:8001
RAG_SERVICE_API_KEY=changeme

# ── cafetera-core (Storage) ─────────────────────────────────────
# PostgreSQL metadata DB + S3/MinIO file storage
# S3/MinIO is shared: admin uses it for uploads, RAG service for parsing/ingestion
DATABASE_URL=postgresql://user:password@localhost:5432/cafetera
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-documents

# ── cafetera-admin ──────────────────────────────────────────────
# Variables needed by the admin web UI (cafetera_admin)
# Admin is lightweight — uploads files to S3 and delegates parsing to RAG service.
ADMIN_API_KEY=change-me-to-a-strong-random-key

# Indexing concurrency (limits parallel document processing in RAG service)
MAX_CONCURRENT_INDEXING=1

# llama-server embedding batch size (default 1024; matches EMBEDDING_CHUNK_SIZE for VRAM efficiency)
# EMBED_UBATCH_SIZE=1024

# llama-server embedding context size (default 4096 with EMBEDDING_CHUNK_SIZE=8)
# Formula: EMBED_CTX_SIZE >= EMBEDDING_CHUNK_SIZE × CHUNK_SIZE (8 × 512 = 4096)
# For EMBEDDING_CHUNK_SIZE=16: set EMBED_CTX_SIZE=8192
# EMBED_CTX_SIZE=4096

# llama-server embedding pooling mode (model-dependent):
#   last  — Qwen3-Embedding, E5-instruct (instruction-following models)
#   mean  — nomic-embed, all-MiniLM, Jina (symmetric models)
#   cls   — BGE, GTE-base (BERT-style models)
EMBED_POOLING=last

# ── GPU Acceleration ────────────────────────────────────────────
# Auto-detected: Apple Silicon (Metal) on macOS, NVIDIA (CUDA) on Linux.
# Override to force a specific mode (99 = all layers on GPU, 0 = CPU only).
# LLM_N_GPU_LAYERS=99
# EMBED_N_GPU_LAYERS=99
# OLLAMA_NUM_GPU=99

# ── llama-server Local Settings ───────────────────────────────
# These only apply when running llama-server directly via scripts/run_llama_*.sh
# (not needed for Ollama or Docker-based deployments).
# LLM_HOST=127.0.0.1
# LLM_PORT=8080
# EMBED_HOST=127.0.0.1
# EMBED_PORT=8090

# ── llama-server model selection ─────────────────────────────
# Which .gguf file llama-server loads (and downloads from *_URL if missing).
# For llama.cpp provider, LLM_MODEL / EMBEDDING_MODEL are just API labels
# (not passed to llama-server) — swap models via *_MODEL_PATH / *_MODEL_URL.
#
# Recommended models (VRAM-optimized with q8_0 KV cache):
#   4B  — Qwen3.5-4B-Q4_K_M   (~5 GB VRAM, fast, good quality)
#   9B  — Qwen3.5-9B-Q4_K_M   (~10 GB VRAM, excellent quality, recommended)
#   14B — Qwen2.5-14B-Q4_K_M  (~14 GB VRAM, best quality, needs 16+ GB GPU)
#
# Defaults are shown below; uncomment and edit to switch models.
# LLM_MODEL_PATH=./models/Qwen3.5-9B-Q4_K_M.gguf
# LLM_MODEL_URL=https://huggingface.co/unsloth/Qwen3.5-9B-GGUF/resolve/main/Qwen3.5-9B-Q4_K_M.gguf
# EMBED_MODEL_PATH=./models/Qwen3-Embedding-0.6B-f16.gguf
# EMBED_MODEL_URL=https://huggingface.co/Qwen/Qwen3-Embedding-0.6B-GGUF/resolve/main/Qwen3-Embedding-0.6B-f16.gguf
# RERANKER_MODEL_URL=https://huggingface.co/Voodisss/Qwen3-Reranker-0.6B-GGUF-llama_cpp/resolve/main/Qwen3-Reranker-0.6B-Q4_K_M.gguf
