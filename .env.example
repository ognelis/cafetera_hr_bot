# Cafetera HR Bot — environment variables
# Copy to .env and fill in real values.

# VK Bot
VK_ACCESS_TOKEN=your_vk_community_token_here
VK_GROUP_ID=0

# RAG / Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hr_documents

# LLM (ollama | openai | llamacpp)
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:4b-q4_K_M
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=

# ── Embedding ───────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_API_KEY=

# Storage (SQLite metadata DB + S3/MinIO file storage)
DB_PATH=data/cafetera.db
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-documents

# Admin panel
ADMIN_API_KEY=change-me-to-a-strong-random-key

# Indexing concurrency (limits parallel document processing)
MAX_CONCURRENT_INDEXING=1

# Example for llama.cpp server:
#   LLM_PROVIDER=llamacpp
#   LLM_BASE_URL=http://localhost:8080/v1
#   LLM_API_KEY=            (leave empty unless --api-key is set on llama-server)
