# Cafetera HR Bot — environment variables
# Copy to .env and fill in real values.

# VK Bot
VK_ACCESS_TOKEN=your_vk_community_token_here
VK_GROUP_ID=0

# RAG / Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hr_documents

# LLM (ollama | openai | llamacpp)
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:4b-q4_K_M
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=

# ── Embedding ───────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:4b-q4_K_M
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_API_KEY=

# Storage (PostgreSQL metadata DB + S3/MinIO file storage)
DATABASE_URL=postgresql://user:password@localhost:5432/cafetera
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-documents

# Admin panel
ADMIN_API_KEY=change-me-to-a-strong-random-key

# Indexing concurrency (limits parallel document processing)
MAX_CONCURRENT_INDEXING=1

# Chunking (token counts — uses tiktoken for accurate token measurement)
# Default 500 tokens stays well under llama-server's 512 default batch
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Chunking strategy: "recursive" (token-based) or "semantic" (embedding similarity)
CHUNK_STRATEGY=recursive
# SemanticChunker settings (only used when CHUNK_STRATEGY=semantic)
# SEMANTIC_BREAKPOINT_THRESHOLD_TYPE=percentile
# SEMANTIC_BREAKPOINT_THRESHOLD_AMOUNT=95

# llama-server embedding batch size (default 1024, increase if needed for large chunks)
# EMBED_UBATCH_SIZE=1024

# ── GPU Acceleration ──────────────────────────────────────────────────────
# Auto-detected: Apple Silicon (Metal) on macOS, NVIDIA (CUDA) on Linux.
# Override to force a specific mode (99 = all layers on GPU, 0 = CPU only).
# LLM_N_GPU_LAYERS=99
# EMBED_N_GPU_LAYERS=99
# OLLAMA_NUM_GPU=99

# Hybrid search settings (requires 'hybrid' optional dependency: uv sync --extra hybrid)
RETRIEVAL_MODE=dense
SPARSE_EMBEDDING_MODEL=Qdrant/bm25
